{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "./dist/",
    "noEmit": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strict": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
		"isolatedModules": true,
    "esModuleInterop": true,
    "allowJs": true,
    "lib": ["dom", "esnext"],
    "types": ["vite/client", "vite-plugin-pwa/client", "vitest/globals"]
  },
  "include": ["src/js/**/*"],
  "exclude": ["node_modules", "**/*.spec.*"]
}
